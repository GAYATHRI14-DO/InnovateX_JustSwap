
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PHILOSOPHY
     * This ruleset implements a strict authorization model for SwapIt, a peer-to-peer item swapping platform.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isParticipant(proposerId, targetOwnerId) {
      return isSignedIn() && (request.auth.uid == proposerId || request.auth.uid == targetOwnerId);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /categories/{categoryId} {
      allow get, list: if true;
    }

    match /users/{ownerId}/items/{itemId} {
      allow get, list: if resource.data.status == 'Available' || isOwner(ownerId);
      allow create: if isOwner(ownerId);
      allow update: if isOwner(ownerId);
      allow delete: if isOwner(ownerId);
    }

    match /{path=**}/items/{itemId} {
      allow read: if resource.data.status == 'Available';
    }

    match /swapProposals/{swapProposalId} {
      // Allow list and get for participants or if the swap is accepted (for public activity feed)
      allow read: if resource.data.status == 'Accepted' 
                  || (isSignedIn() && (request.auth.uid == resource.data.proposerId || request.auth.uid == resource.data.targetItemOwnerId));
      
      allow create: if isSignedIn() && request.resource.data.proposerId == request.auth.uid;
      
      allow update: if isSignedIn() && (request.auth.uid == resource.data.proposerId || request.auth.uid == resource.data.targetItemOwnerId);
      
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.proposerId || request.auth.uid == resource.data.targetItemOwnerId);
    }
  }
}
